```{r setup, include = FALSE}
knitr::opts_chunk$set(
  collapse = TRUE,
  comment = "#>",
  fig.path = "",
  fig.cap = ""
)
find_figure <- function(names) {
  file.path("..", "man", "figures", names)
}
```

